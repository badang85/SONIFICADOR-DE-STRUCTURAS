{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev (Vite)",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": ".", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": ".*(ready in \\d+ ms|Local:\\s+http://localhost:3000).*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
